<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runners_dark_bg">

    <!-- Top Activity Bar -->
    <LinearLayout
        android:id="@+id/activity_status_bar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="Live"
            android:src="@android:drawable/stat_sys_phone_call"
            app:tint="@color/runners_volt" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="RUNNERS"
            android:textColor="@color/runners_volt"
            android:textStyle="bold|italic" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="#262626"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:gravity="center">
            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@android:color/holo_green_light"
                android:layout_marginEnd="6dp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LIVE GPS"
                android:textColor="@color/runners_volt"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/top_timer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="01:12:33"
            android:textColor="@color/runners_text_primary"
            android:textSize="12sp" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/goal_progress_top"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:max="100"
            android:progress="0"
            android:visibility="gone"
            app:indicatorColor="@color/runners_volt"
            app:indicatorSize="20dp"
            app:trackColor="#33FFFFFF"
            app:trackThickness="2dp" />

        <ImageView
            android:id="@+id/btn_search"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:contentDescription="Search"
            android:src="@android:drawable/ic_menu_search"
            app:tint="@color/runners_volt" />

        <ImageView
            android:id="@+id/btn_plans"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginStart="16dp"
            android:contentDescription="Plans"
            android:src="@android:drawable/ic_menu_agenda"
            app:tint="@color/runners_volt" />

    </LinearLayout>

    <!-- Active Workout HUD -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_active_workout_step"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/runners_volt"
        app:cardCornerRadius="16dp"
        app:layout_constraintTop_toBottomOf="@id/activity_status_bar"
        tools:visibility="visible">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <TextView
                android:id="@+id/tv_step_instruction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/onPrimary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="JOG FOR 1 MINUTE" />
            <TextView
                android:id="@+id/tv_step_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/onPrimary"
                android:textSize="14sp"
                tools:text="00:45 REMAINING" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0.3" />

    <!-- Goal Selector -->
    <LinearLayout
        android:id="@+id/goal_selector"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/activity_status_bar">

        <!-- Today's Workout Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_today_workout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#262626"
            app:cardCornerRadius="12dp"
            app:strokeColor="@color/runners_volt"
            app:strokeWidth="1dp"
            tools:visibility="visible">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S WORKOUT"
                    android:textColor="@color/runners_volt"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_today_workout_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textColor="@color/runners_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="First Step (Week 1, Day 1)" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_goals"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:singleSelection="true"
            app:selectionRequired="true">
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_free"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FREE"
                android:textColor="@color/runners_text_primary"
                app:chipBackgroundColor="@color/runners_card_bg"
                app:chipStrokeWidth="0dp"
                android:checked="true" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_5k"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5KM"
                android:textColor="@color/runners_text_primary"
                app:chipBackgroundColor="@color/runners_card_bg"
                app:chipStrokeWidth="0dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_10k"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10KM"
                android:textColor="@color/runners_text_primary"
                app:chipBackgroundColor="@color/runners_card_bg"
                app:chipStrokeWidth="0dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_30m"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30M"
                android:textColor="@color/runners_text_primary"
                app:chipBackgroundColor="@color/runners_card_bg"
                app:chipStrokeWidth="0dp" />
            <com.google.android.material.chip.Chip
                android:id="@+id/chip_route"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ROUTE"
                android:textColor="@color/runners_text_primary"
                app:chipBackgroundColor="@color/runners_card_bg"
                app:chipStrokeWidth="0dp" />
        </com.google.android.material.chip.ChipGroup>
    </LinearLayout>

    <!-- Virtual Pacer Delta -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_pacer_delta"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/runners_dark_bg"
        app:cardCornerRadius="8dp"
        app:strokeColor="@color/runners_volt"
        app:strokeWidth="1dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/goal_selector"
        tools:visibility="visible">
        <TextView
            android:id="@+id/text_pacer_delta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp"
            android:text="+0:05"
            android:textColor="@color/runners_volt"
            android:textSize="14sp"
            android:textStyle="bold" />
    </com.google.android.material.card.MaterialCardView>

    <!-- Metrics Grid -->
    <GridLayout
        android:id="@+id/metrics_grid"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:columnCount="2"
        android:rowCount="2"
        app:layout_constraintTop_toBottomOf="@id/card_pacer_delta">

        <!-- Current Pace -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/runners_card_bg"
            app:cardCornerRadius="8dp"
            app:strokeColor="@color/runners_volt"
            app:strokeWidth="1dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CURRENT PACE"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/data_pace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="4'12''"
                    android:textColor="@color/runners_volt"
                    android:textSize="36sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="/KM"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Distance -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/runners_card_bg"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DISTANCE"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/data_length"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="12.84"
                    android:textColor="@color/runners_text_primary"
                    android:textSize="36sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KILOMETERS"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Duration -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/runners_card_bg"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DURATION"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/data_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="54:02"
                    android:textColor="@color/runners_text_primary"
                    android:textSize="36sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTIVE TIME"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Elevation -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="140dp"
            android:layout_columnWeight="1"
            android:layout_margin="4dp"
            app:cardBackgroundColor="@color/runners_card_bg"
            app:cardCornerRadius="8dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ELEVATION"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/data_elevation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="245"
                    android:textColor="@color/runners_text_primary"
                    android:textSize="36sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="METERS GAINED"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="10sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </GridLayout>

    <!-- Secondary Metrics -->
    <LinearLayout
        android:id="@+id/secondary_metrics"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toBottomOf="@id/metrics_grid">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/runners_card_bg"
            android:layout_marginBottom="8dp"
            android:padding="12dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Heart"
                android:src="@android:drawable/btn_star_big_on"
                app:tint="@color/runners_volt" />
            <TextView
                android:id="@+id/data_bpm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="164 BPM"
                android:textColor="@color/runners_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/runners_card_bg"
            android:padding="12dp"
            android:gravity="center_vertical">
            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Cadence"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/runners_accent_blue" />
            <TextView
                android:id="@+id/data_cadence"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="88 RPM CADENCE"
                android:textColor="@color/runners_text_primary"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- HR Zone Indicator -->
        <LinearLayout
            android:id="@+id/hr_zone_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/runners_card_bg"
            android:layout_marginTop="8dp"
            android:padding="12dp"
            android:gravity="center_vertical"
            android:visibility="gone"
            tools:visibility="visible">
            <TextView
                android:id="@+id/text_hr_zone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZONE 4"
                android:textColor="@color/runners_accent_red"
                android:textSize="18sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/text_hr_zone_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="THRESHOLD"
                android:textColor="@color/runners_text_secondary"
                android:textSize="12sp" />
            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />
            <TextView
                android:id="@+id/text_live_hr"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="172 BPM"
                android:textColor="@color/runners_text_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <!-- Control Bar (Bottom Panel) -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_margin="16dp"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="16dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/button_left"
                android:layout_width="72dp"
                android:layout_height="72dp"
                app:cardBackgroundColor="@color/runners_volt"
                app:cardCornerRadius="16dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:cardElevation="0dp">
                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <ImageView
                        android:id="@+id/pause_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:contentDescription="Pause"
                        android:src="@android:drawable/ic_media_pause"
                        app:tint="@color/onPrimary" />
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/loading_indicator"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        android:indeterminate="true"
                        app:indicatorColor="@color/onPrimary" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <FrameLayout
                android:id="@+id/finish_container"
                android:layout_width="80dp"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/camera_button"
                app:layout_constraintStart_toEndOf="@id/button_left"
                app:layout_constraintTop_toTopOf="parent">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:id="@+id/finish_progress"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:max="100"
                    android:progress="0"
                    android:visibility="invisible"
                    app:indicatorColor="@color/runners_volt"
                    app:indicatorSize="48dp"
                    app:trackColor="#33FFFFFF"
                    app:trackThickness="4dp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:contentDescription="Finish"
                        android:src="@android:drawable/ic_menu_close_clear_cancel"
                        app:tint="@color/runners_text_primary" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="HOLD FINISH"
                        android:textColor="@color/runners_text_secondary"
                        android:textSize="8sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>

            <ImageView
                android:id="@+id/camera_button"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:contentDescription="Camera"
                android:src="@android:drawable/ic_menu_camera"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/runners_text_primary" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
