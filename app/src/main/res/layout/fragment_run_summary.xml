<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runners_dark_bg"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header -->
        <LinearLayout
            android:id="@+id/activity_status_bar"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:background="@color/runners_surface"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="20dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Back"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/runners_volt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:fontFamily="sans-serif-condensed"
                android:text="ACTIVITY"
                android:textColor="@color/runners_volt"
                android:textSize="20sp"
                android:textStyle="bold|italic" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageView
                android:id="@+id/btn_share"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginEnd="16dp"
                android:contentDescription="Share"
                android:src="@android:drawable/ic_menu_share"
                app:tint="@color/runners_volt" />

            <ImageView
                android:id="@+id/btn_delete"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Delete"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/runners_accent_red" />
        </LinearLayout>

        <org.osmdroid.views.MapView
            android:id="@+id/map_summary"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:alpha="0.8"
            app:layout_constraintTop_toBottomOf="@id/activity_status_bar" />

        <!-- Environmental Badge -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/weather_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="-30dp"
            android:layout_marginEnd="16dp"
            app:cardBackgroundColor="@color/runners_dark_bg"
            app:cardCornerRadius="20dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/map_summary"
            app:strokeColor="@color/runners_volt"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp">

                <ImageView
                    android:id="@+id/iv_weather_icon"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:contentDescription="Weather"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/runners_volt" />

                <TextView
                    android:id="@+id/tv_weather_temp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/runners_text_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    tools:text="22°C" />

                <TextView
                    android:id="@+id/tv_environment_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="monospace"
                    android:textColor="@color/runners_volt"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:text="ROAD" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Summary Metrics Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_summary_metrics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/weather_badge"
            app:strokeWidth="0dp">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="16dp">

                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_distance_value"
                        style="@style/MetricValue"
                        tools:text="5.24 km" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/label_distance" />
                </LinearLayout>

                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_pace_value"
                        style="@style/MetricValue"
                        tools:text="5:12" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/label_current_pace" />
                </LinearLayout>

                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_duration_value"
                        style="@style/MetricValue"
                        tools:text="00:27:14" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="@string/label_duration" />
                </LinearLayout>

                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_calories_value"
                        style="@style/MetricValue"
                        tools:text="452 kcal" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="CALORIES" />
                </LinearLayout>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Analysis Controls -->
        <LinearLayout
            android:id="@+id/chart_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="32dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/card_summary_metrics">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="PERFORMANCE ANALYSIS"
                android:textColor="@color/runners_text_secondary"
                android:textSize="10sp"
                android:textStyle="bold" />

            <View
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="0dp" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_metrics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_pace"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:fontFamily="monospace"
                    android:text="PACE"
                    android:textSize="8sp"
                    app:chipBackgroundColor="@color/runners_card_bg"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_hr"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="HR"
                    android:textSize="8sp"
                    app:chipBackgroundColor="@color/runners_card_bg"
                    app:chipStrokeWidth="0dp" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cadence"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:text="CADENCE"
                    android:textSize="8sp"
                    app:chipBackgroundColor="@color/runners_card_bg"
                    app:chipStrokeWidth="0dp" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/summary_chart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/chart_header" />

        <!-- HR Zone Distribution -->
        <TextView
            android:id="@+id/label_zones"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="32dp"
            android:fontFamily="monospace"
            android:text="INTENSITY DISTRIBUTION"
            android:textColor="@color/runners_text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/summary_chart" />

        <com.github.mikephil.charting.charts.HorizontalBarChart
            android:id="@+id/zone_chart"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/label_zones" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
