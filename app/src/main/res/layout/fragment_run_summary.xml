<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runners_dark_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <!-- Custom Status Bar -->
        <LinearLayout
            android:id="@+id/activity_status_bar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/button_back"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/logo_description"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@color/runners_volt" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="@string/title_login"
                android:textColor="@color/runners_volt"
                android:textStyle="bold|italic" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="/ SUMMARY"
                android:textColor="@color/runners_text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <org.osmdroid.views.MapView
            android:id="@+id/map_summary"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:alpha="0.8"
            app:layout_constraintTop_toBottomOf="@id/activity_status_bar" />

        <!-- Summary Metrics Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/metrics_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            app:cardBackgroundColor="@color/runners_card_bg"
            app:cardCornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/map_summary">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="16dp">

                <!-- Distance -->
                <LinearLayout
                    style="@style/MetricLayout"
                    tools:ignore="MissingConstraints">
                    <TextView
                        android:id="@+id/text_distance_value"
                        style="@style/MetricValue"
                        android:text="12.50 km"
                        android:textColor="@color/runners_volt" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="DISTANCE" />
                </LinearLayout>

                <!-- Duration -->
                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_duration_value"
                        style="@style/MetricValue"
                        android:text="01:05:22" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="TIME" />
                </LinearLayout>

                <!-- Pace -->
                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_pace_value"
                        style="@style/MetricValue"
                        android:text="5'12''" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="AVG PACE" />
                </LinearLayout>

                <!-- Calories -->
                <LinearLayout style="@style/MetricLayout">
                    <TextView
                        android:id="@+id/text_calories_value"
                        style="@style/MetricValue"
                        android:text="840 kcal" />
                    <TextView
                        style="@style/MetricLabel"
                        android:text="CALORIES" />
                </LinearLayout>
            </GridLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Pace Analysis Chart -->
        <TextView
            android:id="@+id/label_analysis"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="PACE ANALYSIS"
            android:textColor="@color/runners_text_secondary"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/metrics_card" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/pace_chart"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/label_analysis" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
