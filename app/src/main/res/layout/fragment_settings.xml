<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runners_dark_bg"
    android:clipToPadding="false"
    android:paddingBottom="100dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp">

        <TextView
            android:id="@+id/settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-condensed"
            android:text="@string/settings"
            android:textColor="@color/runners_volt"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/theme_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/settings_title"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Dark Mode Icon"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="@color/runners_volt" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/dark_mode"
                    android:textColor="@color/runners_text_primary" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/theme_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/telemetry_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/theme_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Telemetry Icon"
                    android:src="@android:drawable/ic_menu_mylocation"
                    app:tint="@color/runners_volt" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/telemetry_title"
                    android:textColor="@color/runners_text_primary" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/telemetry_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/social_notifications_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/telemetry_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Social Alerts Icon"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="@color/runners_volt" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="Social Kudos Alerts"
                    android:textColor="@color/runners_text_primary" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/social_notifications_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/unit_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/social_notifications_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="16dp">

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="Unit System Icon"
                    android:src="@android:drawable/ic_menu_directions"
                    app:tint="@color/runners_volt" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif"
                    android:text="@string/unit_system_title"
                    android:textColor="@color/runners_text_primary" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/unit_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/frequency_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/runners_surface"
            app:cardCornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/unit_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/frequency_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="monospace"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="12sp"
                    tools:text="Sync Frequency (minutes): 15" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/frequency_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:valueFrom="5"
                    android:valueTo="60"
                    app:thumbColor="@color/runners_volt"
                    app:trackColorActive="@color/runners_volt"
                    app:trackColorInactive="#33FFFFFF" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/username_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:hint="@string/username_label"
            app:boxStrokeColor="@color/runners_volt"
            app:hintTextColor="@color/runners_volt"
            app:layout_constraintTop_toBottomOf="@id/frequency_card">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/username_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/runners_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/max_hr_layout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Maximum Heart Rate (BPM)"
            app:boxStrokeColor="@color/runners_volt"
            app:hintTextColor="@color/runners_volt"
            app:layout_constraintTop_toBottomOf="@id/username_layout">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/max_hr_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:inputType="number"
                android:textColor="@color/runners_text_primary" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logout_button"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_marginTop="32dp"
            android:fontFamily="monospace"
            android:text="@string/logout_button"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:backgroundTint="@color/runners_accent_red"
            app:cornerRadius="12dp"
            app:layout_constraintTop_toBottomOf="@id/max_hr_layout" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/clear_data_button"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:fontFamily="monospace"
            android:text="CLEAR LOCAL HISTORY"
            android:textColor="@color/runners_text_secondary"
            app:layout_constraintTop_toBottomOf="@id/logout_button" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/sync_progress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:visibility="gone"
            app:indicatorColor="@color/runners_volt"
            app:layout_constraintTop_toBottomOf="@id/clear_data_button"
            app:trackColor="#33FFFFFF" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
