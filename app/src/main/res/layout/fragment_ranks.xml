<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/runners_dark_bg">

    <androidx.core.widget.NestedScrollView
        android:id="@+id/ranks_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        tools:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RANKS"
                        android:textColor="@color/runners_volt"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="WEEKLY TELEMETRY LEADERBOARD"
                        android:textColor="@color/runners_text_secondary"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_search"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:contentDescription="Search"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/runners_volt" />
            </RelativeLayout>

            <!-- Tabs (Interactive) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@color/runners_card_bg"
                android:padding="4dp"
                android:orientation="horizontal">
                <TextView
                    android:id="@+id/tab_global"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@color/runners_volt"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="GLOBAL"
                    android:textColor="@color/onPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tab_clubs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="CLUBS"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tab_friends"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="FRIENDS"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="12sp" />
                <TextView
                    android:id="@+id/tab_challenges"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:padding="8dp"
                    android:text="CHALLENGES"
                    android:textColor="@color/runners_text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>

            <!-- Dynamic Podium -->
            <LinearLayout
                android:id="@+id/podium_container"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="24dp"
                android:gravity="bottom"
                android:orientation="horizontal"
                android:baselineAligned="false">
                <!-- 2nd -->
                <LinearLayout
                    android:id="@+id/podium_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="@color/runners_card_bg"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.SmallComponent" />
                    <TextView
                        android:id="@+id/name_2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="ATHLETE"
                        android:textColor="@color/runners_text_primary"
                        android:textSize="10sp" />
                </LinearLayout>
                <!-- 1st -->
                <LinearLayout
                    android:id="@+id/podium_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.2"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:padding="2dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="@color/runners_volt"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.SmallComponent" />
                    <TextView
                        android:id="@+id/name_1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="CHAMPION"
                        android:textColor="@color/runners_volt"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
                <!-- 3rd -->
                <LinearLayout
                    android:id="@+id/podium_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@android:drawable/ic_menu_gallery"
                        android:background="@color/runners_card_bg"
                        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.SmallComponent" />
                    <TextView
                        android:id="@+id/name_3"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="ATHLETE"
                        android:textColor="@color/runners_text_primary"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Dynamic Ranking List -->
            <LinearLayout
                android:id="@+id/rankings_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="vertical" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loading_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:indeterminate="true"
        app:indicatorColor="@color/runners_volt" />

</FrameLayout>
